<?xml version="1.0" encoding="utf-8"?>
<!--
    Network Security Config — SmartTrip
    • Cleartext (HTTP) only allowed to local development addresses.
    • All production traffic must go over HTTPS.
-->
<network-security-config>
    <!-- Allow cleartext only to local dev servers (emulator + LAN) -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>   <!-- Android emulator localhost -->
        <domain includeSubdomains="false">10.0.3.2</domain>   <!-- Genymotion emulator localhost -->
        <domain includeSubdomains="true">192.168.0.0</domain> <!-- Local network dev -->
        <domain includeSubdomains="true">192.168.1.0</domain>
        <domain includeSubdomains="false">localhost</domain>
    </domain-config>
    <!-- Block cleartext for all other hosts -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
